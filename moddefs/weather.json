{
    "module": "weather",
    "moddef": {
        "name": "weather",
        "position": "middle_left",
        "text_color": "#c0c000",
        "text_bg_color": "#000000",
        "font_name": "DejaVuSans",
        "font_size": 64
    },
    "weather": {
        "url": "https://api.openweathermap.org/data/3.0/onecall",
        "cache_file": "./caches/weather.json",
        "cache_timeout_secs": 840,
        "refresh_minutes": 15,
        "degrees": "°F",
        "datetime_format": "%A, %I:%M:%S %p",
        "lat": "37.50598",
        "lon": "-77.64916",
        "appid": "$OPENWEATHERMAP_API_KEY",
        "exclude": "minutely,hourly",
        "units": "imperial",
        "lang": "english"
    },
    "card": {
        "header": {
            "font_size": 48,
            "text_color": "#000",
            "text_bg_color": "#ff0"
        },
        "body": {
            "font_size": 64,
            "text_color": "#cc0",
            "text_bg_color": "#000"
        },
        "footer": {
            "font_size": 36,
            "text_color": "#cc0",
            "text_bg_color": "#000",
            "valign": "top",
            "height": 48
        }
    }

}