{
    "module": "web_api",
    "moddef": {
        "name": "newsapi.com",
        "position": "middle_right",
        "text_color": "#000000",
        "text_bg_color": "#c0c0c0",
        "font": "DejaVuSans",
        "font_size": 24
    },
    "web_api": {
        "update_mins": 60,
        "cycle_seconds": 15,
        "url": "https://newsapi.org/v2/top-headlines",
        "params": {
            "apiKey": "$NEWSAPI_KEY",
            "country": "us",
            "pageSize": 10,
            "category": "general"
        },
        "display": {
            "total": "{{payload.totalResults}}",
            "max": "10",
            "header": "{{payload.articles[_n_].title}}",
            "body": "{{payload.articles[_n_].description}}",
            "footer": "{{payload.articles[_n_].source.name}} @ {{ payload.articles[_n_].publishedAt.split('T')[0] }} -  {{ payload.articles[_n_].publishedAt.split('T')[1].replace('Z', '') }}"
        }
    },
    "card": {
        "header": {
            "font": "DejaVuSans",
            "font_size": 36,
            "text_color": "#000",
            "text_bg_color": "#088",
            "valign": "top",
            "height": 72
        },
        "body": {
            "font": "DejaVuSans",
            "font_size": 64,
            "text_color": "#0ff",
            "text_bg_color": "#000"
        },
        "footer": {
            "font": "DejaVuSans",
            "font_size": 36,
            "text_color": "#000",
            "text_bg_color": "#088",
            "valign": "bottom",
            "height": 72
        }
    }
}