{
    "module": "web_api",
    "moddef": {
        "name": "newsapi.com",
        "position": "bottom_left",
        "text_color": "#000000",
        "text_bg_color": "#c0c0c0",
        "font": "DejaVuSans",
        "font_size": 24
    },
    "web_api": {
        "update_mins": 60,
        "cycle_seconds": 15,
        "url": "https://newsapi.org/v2/top-headlines",
        "params": {
            "apiKey": "$NEWSAPI_KEY",
            "country": "us",
            "pageSize": 10,
            "category": "general"
        },
        "display": {
            "total": "{{payload.totalResults}}",
            "max": "10",
            "header": "{{payload.articles[_n_].title}}",
            "body": "{{payload.articles[_n_].description}}",
            "footer": "{{payload.articles[_n_].source.name}} @ {{payload.articles[_n_].publishedAt}}"
        }
    },
    "card": {
        "header": {
            "font": "DejaVuSans",
            "font_size": 24,
            "color": "#000",
            "bg_color": "#ccc",
            "valign": "top"
        },
        "body": {
            "font": "DejaVuSans",
            "font_size": 24,
            "color": "#000",
            "bg_color": "#fff"
        },
        "footer": {
            "font": "DejaVuSans",
            "font_size": 24,
            "color": "#000000",
            "bg_color": "#c0c0c0",
            "valign": "top"
        }
    }
}