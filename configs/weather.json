{
    "module": "weather",
    "moddef": {
        "name": "weather",
        "position": "middle_left",
        "text_color": "#c0c000",
        "text_bg_color": "#000000",
        "font": "DejaVuSans",
        "font_size": 64
    },
    "config": {
        "weather_data": {
            "lat": "37.50598",
            "lon": "-77.64916",
            "appid": "$OPENWEATHERMAP_API_KEY",
            "exclude": "minutely,hourly",
            "units": "imperial",
            "lang": "english"
        },
        "body_color": "#c0c000"
    }
}