{
    "module": "web_api",
    "moddef": {
        "name": "newsapi.com",
        "position": "top_center",
        "text_color": "#000000",
        "text_bg_color": "#c0c0c0",
        "font": "DejaVuSans",
        "font_size": 32
    },
    "config": {
        "update_mins": 15,
        "cycle_seconds": 15,
        "url": "https://newsapi.org/v2/top-headlines",
        "params": {
            "apiKey": "$NEWSAPI_KEY",
            "country": "us"
        },
        "colors":
        {
            "background": "#ffffff",
            "title": "#000000",
            "description": "#000000",
            "source": "#000000",
            "publishedAt": "#000000"
        },
        "display": {
            "n": "{{payload.totalResults}}",
            "header": "{{payload.articles[_n_].title}}",
            "body": "{{payload.articles[_n_].description}}",
            "footer": "{{payload.articles[_n_].source.name}} @ {{payload.articles[_n_].publishedAt}}"
        }
    }
}